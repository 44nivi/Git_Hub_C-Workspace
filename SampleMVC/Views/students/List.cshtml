@{
}

@model List<SampleMVC.Models.Student>
<h1>Students List </h1>

<form method="post">

<style>
    table, td, th {
        border: 1px solid #ddd;
        text-align: left;
    }

    table {
        border-collapse: collapse;
        width: 100%;
    }

    th, td {
        padding: 15px;
    }
    
</style>
<table class="Table">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Description</th>
        <th>Phone</th>
        <th>Email</th>
        <th>Edit</th>
    </tr>
  
    <tbody>
        @foreach(var student in Model){
    <tr>
        <td> @student.Id</td>
        <td> @student.Name</td>
        <td> @student.Description</td>
        <td> @student.Phone</td>
        <td> @student.Email</td>
        <td> 
        <a asp-controller="students" asp-action="Edit1" asp-route-id="@student.Id">Edit</a>

       </td>

    </tr>   
        }
    </tbody>
</table>
</form>