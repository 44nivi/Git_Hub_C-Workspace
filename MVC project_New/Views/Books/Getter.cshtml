@{
}
@model MVC_project_New.Models.Book



<form method="get">

    <style>
        table, td, th {
            border: 1px solid #ddd;
            text-align: left;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        th, td {
            padding: 15px;
        }
    </style>

    <table class="Table">
        <tr>
            <th>BookName</th>
            <th>Price</th>
            <th>Category</th>
            <th>Author</th>
            
        </tr>

        <tbody>
            {
                <tr>
                    <td> @Model.BookName.</td>
                    <td> @Model.Price</td>
                    <td> @Model.Category</td>
                    <td> @Model.Author</td>
               
                    <td>
                        <a asp-controller="students" asp-action="Edit1" asp-route-id="@Model.Id">Edit</a>

                    </td>

                </tr>
            }
        </tbody>
    </table>
</form>