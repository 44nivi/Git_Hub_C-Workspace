@{
}
@model List<MVC_project_New.Models.Book>


<form method="get">

    <style>
        table, td, th {
            border: 1px solid #ddd;
            text-align: left;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        th, td {
            padding: 15px;
        }
    </style>

    <table class="Table">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Description</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Edit</th>
        </tr>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td> @item.Id</td>
                    <td> @item.Price</td>
                    <td> @item.BookName</td>
                    <td> @item.Author</td>
                    <td> @item.Category</td>
                    <td>
                        <a asp-controller="Books" asp-action="Edit1" asp-route-id="@item.Id">Edit</a>

                    </td>

                </tr>
            }
        </tbody>
    </table>
</form>