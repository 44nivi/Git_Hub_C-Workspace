@{
    ViewBag.Title = "Home Page";
}

<main>
    <section class="row" aria-labelledby="aspnetTitle">
        <h1 id="title">CineMax</h1>
        <p class="lead">Welcome to CineMax Theatre !!Experience the Virtual Environment Effects!!</p>
        <p><a href="https://asp.net" class="btn btn-primary btn-md">Learn more &raquo;</a></p>
    </section>

    <div class="row">
        <section class="col-md-4" aria-labelledby="gettingStartedTitle">
            <h2 id="gettingStartedTitle">Commercial Super Hits</h2>
            <p>
                Commercial hits through CineMax COIMBATORE, will lead to impressivebrand outreach, considering the number of screens nationwide 
                and the irrespective seating capacity. With a collective reach of more than 2.6 Lakhpeople, display advertising at 
                Cinemax would ensure a high ROI for your advertising campaign and successful execution of your advertisingstrategies, leading to 
                a distinctive and widespread Brand Positioning amongstthe target audience. 
            </p>
            <p><a class="btn btn-outline-dark" href="https://go.microsoft.com/fwlink/?LinkId=301865">Learn more &raquo;</a></p>
        </section>
        <section class="col-md-4" aria-labelledby="librariesTitle">
           
        </section>
        <section class="col-md-4" aria-labelledby="hostingTitle">
            @model Mvc_sample_Project_2.Models.Customers
            @using (Html.BeginForm("AddCustomer", "Movies", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="form-horizontal">
                    <h4>Customer Details</h4>
                    <hr />
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    <div class="form-group">
                        @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "control-label col-md-2" })
                        <div class="col-md-10">
                            @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                        </div>
                    </div>

             
                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">
                            <input type="submit" value="Create" class="btn btn-default" />
                        </div>
                    </div>
                </div>
            }


        </section>
        </div>
</main>